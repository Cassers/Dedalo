# --- Base de datos (Postgres propio de Dédalo) ---
DATABASE_URL="postgres://dedalo:dedalo_dev_pw@localhost:5433/dedalo"

# --- Sesión ---
# Secreto para firmar la cookie de sesión (HMAC). Usa una cadena larga y aleatoria.
SESSION_SECRET="cambia-esto-por-algo-aleatorio-largo"
# Password de admin (opcional).
# ADMIN_PASSWORD=""

# --- Login con Discord (OAuth2) ---
# USA LA MISMA APP DE DISCORD QUE PROBATOR para identidad compartida (SSO-lite).
# Agrega el redirect URI de Dédalo en el portal de Discord:
#   <PUBLIC_BASE_URL>/auth/discord/callback
# Si quedan vacías, el login con Discord se oculta y Dédalo funciona igual (sin guardar funciones).
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
# Opcional: exige pertenecer a este servidor de Discord. Vacío = cualquiera entra.
# DISCORD_GUILD_ID=""

# Base URL pública (para construir el redirect de OAuth). En local, http://localhost:5173
PUBLIC_BASE_URL="http://localhost:5173"

# --- Integración opcional con Probator (Fase 2) ---
# Si están vacías, los controles de retos/juzgar se ocultan (degradación elegante).
PROBATOR_API_URL=""
PROBATOR_API_KEY=""
